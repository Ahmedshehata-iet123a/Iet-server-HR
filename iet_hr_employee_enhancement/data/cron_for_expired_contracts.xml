<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="1">

        <record id="ir_cron_scheduler_contract_action" model="ir.cron">
            <field name="name">Active Expire Contracts</field>
            <field name="model_id" ref="model_hr_contract"/>
            <field name="state">code</field>
            <field name="code">model.action_is_cheked()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
<!--            <field name="numbercall">-1</field>-->
            <field name="nextcall" eval="(DateTime.now() + timedelta(hours=1))"/>
            <field name="user_id" ref="base.user_root"/>
<!--            <field name="doall" eval="False"/>-->
        </record>

        <record id="ir_cron_check_employee" model="ir.cron">
            <field name="name">Check the expiration of employee contracts and identities.</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="state">code</field>
            <field name="code">model.notify_employee_date()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
<!--            <field name="numbercall">-1</field>-->
            <field name="active">True</field>
        </record>

    </data>
</odoo>
