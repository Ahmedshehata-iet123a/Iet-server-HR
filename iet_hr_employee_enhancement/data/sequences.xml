<odoo>
    <data>

        <record id="employee_badge_number_sequence" model="ir.sequence">
            <field name="name">Employee Badge Number Sequence</field>
            <field name="code">hr.employee.badge.number</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="implementation">no_gap</field>
        </record>

        <record id="location_transfer_sequence" model="ir.sequence">
            <field name="name">location transfer</field>
            <field name="code">location.transfer</field>
            <field name="prefix">LOC/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>


        <record id="ir_sequence_employee_number" model="ir.sequence">
            <field name="name">Employee Number Sequence</field>
            <field name="code">employee_number.seq.code</field>
            <field name="padding">5</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="emp_report_seq" model="ir.sequence">
            <field name="name">Employee Analytic Sequence</field>
            <field name="code">emp.report.seq</field>
            <field name="prefix">ER-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>