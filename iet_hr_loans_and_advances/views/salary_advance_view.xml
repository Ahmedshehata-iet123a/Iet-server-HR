<?xml version="1.0" ?>
<odoo>
    <data>
        <record id="id_salary_advance_view_tree" model="ir.ui.view">
            <field name="name">salary.advance.view.tree</field>
            <field name="model">salary.advance</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="date"/>
                    <field name="deduction_date"/>
                    <field name="employee_id"/>
                    <field name="employee_number"/>
                    <field name="department_id"/>
                    <field name="amount"/>
                    <field name="state"/>
                </list>
            </field>
        </record>


        <record id="id_salary_advance_view_form" model="ir.ui.view">
            <field name="name">salary.advance.view.form</field>
            <field name="model">salary.advance</field>
            <field name="arch" type="xml">
                <form string="salary advance">
                    <header>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,confirm,paid"/>
                        <button name="validate_action" type="object" string="HR Validate" class="oe_highlight"
                                invisible="state != 'draft'"
                                groups="iet_hr_employee_enhancement.group_hr_officer, iet_hr_employee_enhancement.group_hr_manager"/>
                        <button name="financial_manager" type="object" string="Financial Manager Approve"
                                class="oe_highlight"
                                invisible="state != 'financial_manager'"
                                groups="iet_hr_employee_enhancement.group_finance_manager"
                        />
                        <button name="general_manager" type="object" string="General Manager Approve"
                                class="oe_highlight"
                                invisible="state != 'general_manager'"
                                groups="iet_hr_employee_enhancement.group_general_manager"
                        />
                        <button name="paid" type="object" string="Pay" class="oe_highlight"
                                invisible="state != 'confirm'" groups="iet_hr_employee_enhancement.group_account_paid"/>
                        <button name="rejected" type="object" string="Reject" class="btn-secondary"
                                invisible="state in ['draft', 'rejected',]"
                                groups="iet_hr_employee_enhancement.group_hr_officer, iet_hr_employee_enhancement.group_hr_manager"/>
                        <button name="back_to_draft" type="object" string="Reset To Draft" class="btn-secondary"
                                invisible="state != 'rejected'"
                        />
                    </header>
                    <sheet>
                        <div class="oe_title mb8">
                            <h1 class="o_row">
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="employee_id" readonly="state != 'draft'"/>
                                <field name="employee_number"/>
                                <field name="company_id" invisible="1"/>
                                <field name="barcode_for_advance"/>
                                <field name="identification_for_advance"/>
                                <field name="department_id"/>
                                <field name="amount" readonly="state != 'draft'"/>
                                <field name="reason" readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="date" readonly="state != 'draft'"/>
                                <field name="deduction_date" readonly="state != 'draft'"/>
                                <field name="emp_customs_analytic_id"/>
                                <field name="journal_id"
                                       invisible="state != 'confirm'" required="state == 'confirm'"/>
                                <field name="account_id"
                                       invisible="state != 'confirm'" required="state == 'confirm'"/>
                                <field name="account_idd"
                                       invisible="state != 'confirm'" required="state == 'confirm'"/>
                                <field name="journal_entry_id"
                                       invisible="state != 'paid'"/>
                                <field name="type" invisible="1"/>
                            </group>
                        </group>
                    </sheet>
                    <chatter/>

                </form>
            </field>
        </record>


        <record id="id_salary_advance_view_search" model="ir.ui.view">
            <field name="name">salary.advance.view.search</field>
            <field name="model">salary.advance</field>
            <field name="arch" type="xml">
                <search string="Search salary.advance">
                    <field name="name"/>
                    <field name="deduction_date"/>
                    <field name="employee_id"/>
                    <field name="employee_number"/>
                    <field name="state"/>
                    <field name="date"/>
                    <field name="amount"/>
                    <field name="department_id"/>
                    <field name="journal_id"/>
                    <field name="account_id"/>
                    <field name="account_idd"/>
                </search>
            </field>
        </record>

        <record id="id_salary_advance_view_action" model="ir.actions.act_window">
            <field name="name">salary advance</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">salary.advance</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- This Menu Item must have a parent and an action -->


        <!--        <menuitem-->
        <!--            id="menu_loans__action"-->
        <!--            sequence="1"-->
        <!--            parent="iet_hr_loans_and_advances.menu_loans_main_menu"-->
        <!--            name="Loans And Advances"-->
        <!--    />-->


        <menuitem id="menu_salary_advance__action_categ" name="Salary Advance"
                  parent="iet_hr_loans_and_advances.menu_loans_main_menu" action="id_salary_advance_view_action"
                  sequence="2"
        />
        <!--    parent="menu_loans__action"-->

        <!--        # menu for acount-->

        <record id="id_salary_advance_account_view_action" model="ir.actions.act_window">
            <field name="name">salary advance</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">salary.advance</field>
            <field name="domain">[('state','=','confirm')]</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- This Menu Item must have a parent and an action -->

        <!--    <menuitem id="menu_salary_advance_account_action_categ" name="Salary Advance" parent="menu_loans_acount_action"-->
        <!--              action="id_salary_advance_account_view_action" sequence="1"/>-->

    </data>

</odoo>
