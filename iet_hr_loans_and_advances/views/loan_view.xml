<?xml version="1.0" ?>
<odoo>
    <data>

        <record id="type_loan_advance_view_tree" model="ir.ui.view">
            <field name="name">type.loan.advance.view.tree</field>
            <field name="model">type.loan.advance</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                </list>
            </field>
        </record>

        <record id="type_loan_advance_view_form" model="ir.ui.view">
            <field name="name">type.loan.advance.view.tree</field>
            <field name="model">type.loan.advance</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                            </group>
                            <group>
                            </group>
                        </group>
                    </sheet>
                    <chatter/>

                </form>
            </field>
        </record>

        <record id="type_loan_advance_action" model="ir.actions.act_window">
            <field name="name">Types</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">type.loan.advance</field>
            <field name="view_mode">list,form</field>
        </record>


        <record id="id_loans_view_tree" model="ir.ui.view">
            <field name="name">loans.view.tree</field>
            <field name="model">loans</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="date"/>
                    <field name="deduction_date"/>
                    <field name="employee_id"/>
                    <field name="employee_number"/>
                    <field name="department_id"/>
                    <field name="amount"/>
                    <field name="no_of_installment"/>
                    <field name="state"/>
                </list>
            </field>
        </record>


        <record id="id_loans_view_form" model="ir.ui.view">
            <field name="name">loans.view.form</field>
            <field name="model">loans</field>
            <field name="arch" type="xml">
                <form string="loans">
                    <header>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,confirm,paid,reconcile"/>
                        <button name="compute_installment" type="object" string="Compute Installment"
                                class="oe_highlight"
                                invisible="state in ['confirm','rejected','paid']"/>
                        <button name="validate_action" type="object" string="HR Validate" class="oe_highlight"
                                invisible="state != 'draft'"
                                groups="iet_hr_employee_enhancement.group_hr_officer, iet_hr_employee_enhancement.group_hr_manager"/>
                        <button name="financial_manager" type="object" string="Financial Manager Approve"
                                class="oe_highlight"
                                invisible="state != 'financial_manager'"
                                groups="iet_hr_employee_enhancement.group_finance_manager"
                        />
                        <button name="general_manager" type="object" string="General Manager Approve"
                                class="oe_highlight"
                                invisible="state != 'general_manager'"
                                groups="iet_hr_employee_enhancement.group_general_manager"
                        />
                        <button name="paid" type="object" string="Pay" class="oe_highlight"
                                invisible="state != 'confirm'"
                                groups="iet_hr_employee_enhancement.group_account_paid"/>
                        <button name="paid2" type="object" string="To Reconcile" class="oe_highlight"
                                invisible="state != 'paid'"
                                groups="iet_hr_employee_enhancement.group_account_paid"/>
                        <button name="reconcile_amount" type="object" string="Reconcile Amount" class="oe_highlight"
                                invisible="state != 'paid2'"
                                groups="iet_hr_employee_enhancement.group_account_paid"/>

                        <button name="action_compute" type="object" string="Compute" class="oe_highlight"
                                invisible="state != 'paid'"/>
                        <button name="rejected" type="object" string="Reject"
                                invisible="state in ['draft', 'rejected',]"
                                class="btn-secondary"
                                groups="iet_hr_employee_enhancement.group_hr_officer, iet_hr_employee_enhancement.group_hr_manager"/>
                        <button name="back_to_draft" type="object" string="Reset To Draft" class="btn-secondary"
                                invisible="state != 'rejected'"/>
                    </header>
                    <sheet>
                        <div class="oe_title mb8">
                            <h1 class="o_row">
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="journal_entry_id" invisible="1"/>
                                <field name="company_id" invisible="1"/>
                                <field name="employee_id" readonly="state != 'draft'"/>
                                <field name="employee_number"/>
                                <field name="barcode_for_loan"/>
                                <field name="identification_for_loan"/>
                                <field name="amount" readonly="state != 'draft'"/>
                                <field name="amount_not_paid" readonly="state != 'draft'"/>
                                <field name="no_of_installment" readonly="state != 'draft'"/>
                                <field name="journal_id"
                                       invisible="state != 'confirm'" required="state == 'confirm'"/>
                                <field name="journal_id_reconcile_account"
                                       invisible="state != 'paid2'" required="state == 'paid2'"/>
                                <field name="debit_reconcile_account"
                                       invisible="state != 'paid2'" required="state == 'paid2'"/>
                                <field name="credit_reconcile_account"
                                       invisible="state != 'paid2'" required="state == 'paid2'"/>
                            </group>
                            <group>
                                <field name="department_id"/>
                                <field name="date" readonly="state != 'draft'"/>
                                <field name="deduction_date" readonly="state != 'draft'"/>
                                <field name="employees_customs_analytics_id"/>
                                <field name="account_id"
                                       invisible="state != 'confirm'" required="state != 'confirm'"/>
                                <field name="account_idd"
                                       invisible="state != 'confirm'" required="state != 'confirm'"/>
                                <field name="type" invisible="1"/>
                                <field name="journal_entry_id" invisible="state != 'paid'"/>
                                <field name="journal_entry_id_for_reconcile" invisible="state != 'reconcile'"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Installment" name="installment">
                                <field name="loans_ids" widget="one2many">

                                    <list editable="bottom" create="false" delete="true">
                                        <field name="name" readonly="1"/>
                                        <!--                      attrs="{'readonly': [('delay', '=', True)]}"-->
                                        <field name="delay" readonly="delay == True" force_save="1"/>
                                        <field name="amount" readonly="1"/>
                                        <field name="is_paid" invisible="0" force_save="1" readonly="1"/>
                                        <field name="is_created" invisible="1"/>
                                    </list>

                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>

                </form>
            </field>
        </record>

        <record id="id_loans_view_search" model="ir.ui.view">
            <field name="name">loans.view.search</field>
            <field name="model">loans</field>
            <field name="arch" type="xml">
                <search string="Search loans">
                    <field name="name"/>
                    <field name="deduction_date"/>
                    <field name="employee_id"/>
                    <field name="employee_number"/>
                    <field name="date"/>
                    <field name="state"/>
                    <field name="amount"/>
                    <field name="no_of_installment"/>
                    <field name="department_id"/>
                    <field name="journal_id"/>
                    <field name="account_id"/>
                    <field name="account_idd"/>
                </search>
            </field>
        </record>

        <record id="id_loans_view_action" model="ir.actions.act_window">
            <field name="name">loans</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">loans</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="iet_hr_loans_and_advances.menu_loans_main_menu"
                  name="Loans"
                  web_icon="iet_hr_loans_and_advances,static/description/icon.png"
                  sequence="200"

        />

        <menuitem id="menu_loans__action_categ"
                  name="Loans" parent="iet_hr_loans_and_advances.menu_loans_main_menu"
                  action="id_loans_view_action"
                  sequence="1"
        />

        <record id="id_loans_account_view_action" model="ir.actions.act_window">
            <field name="name">loans</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">loans</field>
            <field name="domain">[('state','=','confirm')]</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>

</odoo>
