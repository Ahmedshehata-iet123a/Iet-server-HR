<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
  <data noupdate="0">

    <record id="structure_accrual_leave" model="hr.payroll.structure">
      <field name="name">Accrual Leave</field>
      <field name="type_id" ref="l10n_sa_hr_payroll.ksa_employee_payroll_structure_type"/>
      <field name="country_id" ref="base.sa"/>
    </record>

    <record id="hr_rule_accrual_leave" model="hr.salary.rule">
      <field name="name">Accrual Leave Rule</field>
      <field name="sequence" eval="1"/>
      <field name="code">ALR</field>
      <field name="struct_id" ref="iet_hr_payroll_enhancement.structure_accrual_leave"/>
      <field name="category_id" ref="hr_payroll.ALW"/>
      <field name="condition_select">none</field>
      <field name="amount_select">code</field>
      <field name="amount_python_compute">result = payslip.accrual_leave</field>
    </record>

    <record id="structure_leave_from_company" model="hr.payroll.structure">
      <field name="name">خروج نهائي</field>
      <field name="type_id" ref="l10n_sa_hr_payroll.ksa_employee_payroll_structure_type"/>
      <field name="country_id" ref="base.sa"/>
    </record>

    <record id="hr_rule_departure_exceptional_request" model="hr.salary.rule">
      <field name="name">الاستقالة / طلب استثنائي</field>
      <field name="sequence" eval="1"/>
      <field name="code">ER</field>
      <field name="struct_id" ref="iet_hr_payroll_enhancement.structure_leave_from_company"/>
      <field name="category_id" ref="hr_payroll.ALW"/>
      <field name="sequence">50</field>
      <field name="condition_select">python</field>
      <field name="condition_python">result = not employee.active and employee.departure_reason_id in [contract.env.ref('iet_hr_payroll_enhancement.departure_exceptional_request'), contract.env.ref('iet_hr_payroll_enhancement.departure_resignation')]</field>
      <field name="amount_select">code</field>
      <field name="amount_python_compute">result = employee.get_exceptional_request_departure_resignation(employee.id,payslip.date_from,payslip.date_to)</field>
    </record>

    <record id="hr_rule_departure_resignation" model="hr.salary.rule">
      <field name="name">الاستقالة</field>
      <field name="sequence" eval="1"/>
      <field name="code">DR</field>
      <field name="struct_id" ref="iet_hr_payroll_enhancement.structure_leave_from_company"/>
      <field name="category_id" ref="hr_payroll.ALW"/>
      <field name="sequence">60</field>
      <field name="condition_select">python</field>
      <field name="condition_python">result = not employee.active and employee.departure_reason_id in [contract.env.ref('iet_hr_payroll_enhancement.departure_resignation')]</field>
      <field name="amount_select">code</field>
      <field name="amount_python_compute">result = employee.get_exceptional_request_departure_resignation(employee.id,payslip.date_from,payslip.date_to)</field>
    </record>

    <record id="hr_rule_termination_of_the_contract_by_the_company" model="hr.salary.rule">
      <field name="name">إنهاء العقد / إنهاء العقد من قبل الشركة</field>
      <field name="sequence" eval="1"/>
      <field name="code">TOTCBTC</field>
      <field name="struct_id" ref="iet_hr_payroll_enhancement.structure_leave_from_company"/>
      <field name="category_id" ref="hr_payroll.ALW"/>
      <field name="sequence">70</field>
      <field name="condition_select">python</field>
      <field name="condition_python">result = not employee.active and employee.departure_reason_id in [contract.env.ref('iet_hr_payroll_enhancement.termination_of_the_contract_by_the_company'), contract.env.ref('iet_hr_payroll_enhancement.end_of_the_contract')]</field>
      <field name="amount_select">code</field>
      <field name="amount_python_compute">result = employee.get_termination_of_the_contract_by_the_company(employee.id,payslip.date_from,payslip.date_to)</field>
    </record>

    <record id="hr_rule_end_of_the_contract" model="hr.salary.rule">
      <field name="name">إنهاء العقد</field>
      <field name="sequence" eval="1"/>
      <field name="code">EOTC</field>
      <field name="struct_id" ref="iet_hr_payroll_enhancement.structure_leave_from_company"/>
      <field name="category_id" ref="hr_payroll.ALW"/>
      <field name="sequence">80</field>
      <field name="condition_select">python</field>
      <field name="condition_python">result = not employee.active and employee.departure_reason_id in [contract.env.ref('iet_hr_payroll_enhancement.end_of_the_contract')]</field>
      <field name="amount_select">code</field>
      <field name="amount_python_compute">result = employee.get_termination_of_the_contract_by_the_company(employee.id,payslip.date_from,payslip.date_to)</field>
    </record>

  </data>
</odoo>
