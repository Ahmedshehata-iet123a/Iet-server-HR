<odoo>
    <data>

        <record id="view_hr_payslip_filter_inherit" model="ir.ui.view">
            <field name="name">hr_payroll.hr_payslip.inherit.search</field>
            <field name="model">hr.payslip</field>
            <field name="inherit_id" ref="hr_payroll.view_hr_payslip_filter"/>
            <field name="arch" type="xml">
                <field name="employee_id" position="after">
                    <field name="employee_number" string="Employee Number"/>
                </field>
            </field>
        </record>

        <record id="hr_payslip_form_inherit00" model="ir.ui.view">
            <field name="name">hr.payslip.form.inherit</field>
            <field name="model">hr.payslip</field>
            <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='employee_id']" position="after">
                    <field name="accrual_leave" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='struct_id']" position="after">
                    <field name="show_last_payslip"/>
                </xpath>

                <xpath expr="//page[@name='worked_days_input']" position="replace">
                    <page string="Worked Days &amp; Inputs" name="worked_days_input">
                        <separator string="Worked Days" invisible="1"/>
                        <field name="worked_days_line_ids" invisible="1">
                            <list string="Worked Days" editable="bottom" create="0" delete="0">
                                <field name="work_entry_type_id" readonly="1" force_save="1"/>
                                <field name="name"/>
                                <field name="number_of_days" sum="Total Working Days" readonly="1" force_save="1"/>
                                <field name="number_of_hours" sum="Total Working Hours" readonly="1" force_save="1"/>
                                <field name="amount" readonly="1" sum="Total Amount" force_save="1"/>
                                <field name="is_paid" invisible="True" readonly="1" force_save="1"/>
                                <field name="sequence" invisible="True" readonly="1" force_save="1"/>
                                <field name="currency_id" invisible="1"/>
                            </list>
                            <form string="Worked Day">
                                <group col="4">
                                    <field name="work_entry_type_id"/>
                                    <field name="name"/>
                                    <field name="sequence"/>
                                    <field name="number_of_days"/>
                                    <field name="number_of_hours" widget="float_time"/>
                                    <field name="amount"/>
                                    <field name="is_paid"/>
                                    <field name="contract_id"/>
                                    <field name="currency_id" invisible="1"/>
                                </group>
                            </form>
                        </field>
                        <group>
                            <group>
                                <field name="number_of_absences_days" readonly="0"/>
                                <field name="amount_of_absences"/>
                                <field name="customs_attendances"/>
                                <field name="amount_of_attendances"/>
                            </group>
                            <group>
                                <field name="number_of_penalties_days" readonly="0"/>
                                <field name="amount_of_penalties"/>
                                <field name="overtime_hours" readonly="0"/>
                                <field name="overtime_amount"/>
                            </group>
                        </group>
                        <separator string="Other Inputs"/>
                        <div class="alert alert-warning" role="alert"
                             invisible="'negative_net_to_report_display', '=', False">
                            <field name="negative_net_to_report_message"/>
                            <button name="action_report_negative_amount" class="oe_link" type="object"
                                    string=" -&gt; Report"/>
                        </div>
                        <field name="input_line_ids" colspan="4" nolabel="1">
                            <list string="Input Data" editable="bottom">
                                <!--
                                    Required 0 to force client to send on change request even when not defined
                                    Salary Attachments would otherwise not properly be computed and payslip_id is
                                    required for _allowed_input_type_ids to work..
                                -->
                                <field name="payslip_id" invisible="1" required="0"/>
                                <field name="_allowed_input_type_ids" invisible="1"/>
                                <field name="input_type_id"/>
                                <field name="name"/>
                                <field name="amount"/>
                                <field name="contract_id" invisible="True"/>
                                <field name="sequence" invisible="True"/>
                            </list>
                            <form string="Payslip Line">
                                <group col="4">
                                    <field name="payslip_id" invisible="1"/>
                                    <field name="_allowed_input_type_ids" invisible="1"/>
                                    <field name="input_type_id"/>
                                    <field name="name"/>
                                    <field name="sequence"/>
                                    <field name="amount"/>
                                    <field name="contract_id"/>
                                </group>
                            </form>
                        </field>
                    </page>
                </xpath>

            </field>
        </record>


    </data>
</odoo>