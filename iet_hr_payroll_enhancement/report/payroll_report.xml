<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model="report.paperformat" id="paperformat_report">
            <field name="name">A4 report</field>
            <field name="default" eval="True"/>
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">15</field>
            <field name="margin_bottom">10</field>
            <field name="margin_left">2</field>
            <field name="margin_right">5</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">30</field>
            <field name="dpi">90</field>
        </record>

        <record id="payroll_report_action" model="ir.actions.report">
            <field name="name">Payroll Report</field>
            <field name="model">hr.payslip</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">iet_hr_payroll_enhancement.payroll_form_view</field>
            <field name="report_file">iet_hr_payroll_enhancement.payroll_form_view</field>
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="iet_hr_payroll_enhancement.paperformat_report"/>
        </record>

        <template id="payroll_form_view">
            <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <div class="page">
                    <div>
                        <h3  class='mt0' style="color:#4A2F7E;font-size:28px;text-align:center"> Payroll Report</h3>
                    </div>
                    <br></br>
                    <style>
                        @font-face {
                        font-family: 'Tajawal-Regular';
                        src: local('Tajawal-Regular'), local('Tajawal-Regular'),
                        url(/iet_hr_payroll_enhancement/static/src/fonts/tajawal/Tajawal-Regular.ttf)
                        format('opentype');
                        }

                        .font_tajawal{
                        font-family: Tajawal-Regular;
                        }

                        tr:nth-child(even) {
                        background-color: #eee;
                        }
                        tr:nth-child(odd) {
                        background-color: #fff;
                        }
                        th {
                        background-color: #0000FF;
                        color: black;
                        }
                    </style>
                    <table class='styled-table mt-2 font_tajawal'  style="border-collapse: collapse;border: 1px solid #ddd;font-size:14px; width:100%;padding-top:0;margin-top:0;direction: ltr;">
                        <tr class="thead-light" style="padding:0px; margin:0px;border-top: 2px solid #ddd;">
                            <th class="text-center" style="background-color:#D3D3D3;padding: 8px;border: 2px solid #ddd;text-align: center;width: 20%">
                                Employee
                            </th>
                            <td class="text-center" style="padding: 8px;border: 2px solid #ddd;text-align: center;width: 30%" colspan="3">
                             <t t-esc="employee_id"/>
                            </td>
                        </tr>
                        <tr class="thead-light" style="padding:0px; margin:0px;border-top: 2px solid #ddd;">
                            <th class="text-center" style="background-color:#D3D3D3;padding: 8px;border: 2px solid #ddd;text-align: center;width: 20%">
                                From
                            </th>
                            <td class="text-center" style="padding: 8px;border: 2px solid #ddd;text-align: center;width: 30%">
                                <t t-esc="date_from"/>
                            </td>
                            <th class="text-center"
                                style="background-color:#D3D3D3;padding: 8px;border: 2px solid #ddd;text-align: center;width: 20%">
                                to
                            </th>
                            <td class="text-center" style="padding: 8px;border: 2px solid #ddd;text-align: center;width: 30%">
                                <t t-esc="date_to"/>
                            </td>
                        </tr>
                        <tr class="thead-light" style="padding:0px; margin:0px;border-top: 2px solid #ddd;">
                            <th class="text-center" style="background-color:#D3D3D3;padding: 8px;border: 2px solid #ddd;text-align: center;width: 20%">
                                Number
                            </th>
                            <td class="text-center" style="padding: 8px;border: 2px solid #ddd;text-align: center;width: 30%">
                                <t t-esc="number"/>
                            </td>
                            <th class="text-center"
                                style="background-color:#D3D3D3;padding: 8px;border: 2px solid #ddd;text-align: center;width: 20%">
                                Contract
                            </th>
                            <td class="text-center" style="padding: 8px;border: 2px solid #ddd;text-align: center;width: 30%">
                                <t t-esc="contract_id" />
                            </td>
                        </tr>
                        <tr class="thead-light" style="padding:0px; margin:0px;border-top: 2px solid #ddd;">
                            <th class="text-center" style="background-color:#D3D3D3;padding: 8px;border: 2px solid #ddd;text-align: center;width: 20%">
                                Batch
                            </th>
                            <td class="text-center" style="padding: 8px;border: 2px solid #ddd;text-align: center;width: 30%">
                                <t t-esc="payslip_run_id" />
                            </td>
                            <th class="text-center" style="background-color:#D3D3D3;padding: 8px;border: 2px solid #ddd;text-align: center;width: 20%">
                                Structure
                            </th>
                            <td class="text-center" style="padding: 8px;border: 2px solid #ddd;text-align: center;width: 30%">
                                <t t-esc="struct_id"/>
                            </td>
                        </tr>
                        <tr class="thead-light" style="padding:0px; margin:0px;border-top: 2px solid #ddd;">
                            <th class="text-center" style="background-color:#D3D3D3;padding: 8px;border: 2px solid #ddd;text-align: center;width: 20%">
                                Last Working Date
                            </th>
                            <td class="text-center" style="padding: 8px;border: 2px solid #ddd;text-align: center;width: 30%">
                                <t t-esc="last_working_date" />
                            </td>
                            <th class="text-center" style="background-color:#D3D3D3;padding: 8px;border: 2px solid #ddd;text-align: center;width: 20%">
                                The date of the holiday
                            </th>
                            <td class="text-center" style="padding: 8px;border: 2px solid #ddd;text-align: center;width: 30%">
                                <t t-esc="request_date_from"/>
                            </td>
                        </tr>

                    </table>
                    <br></br>
                    <br></br>
                    <table class='styled-table mt-2 font_tajawal'  style="border-collapse: collapse;border: 1px solid #ddd;font-size:14px; width:100%;padding-top:0;margin-top:0;direction: ltr;">
                        <tr class="thead-light" style="padding:0px; margin:0px;border-top: 2px solid #ddd;">
                            <th class="text-center" style="background-color:#D3D3D3; color:black;width: 25%">Name</th>
                            <th class="text-center" style="background-color:#D3D3D3; color:black;width: 15%">Category</th>
                            <th class="text-center" style="background-color:#D3D3D3; color:black;width: 10%">Quantity</th>
                            <th class="text-center" style="background-color:#D3D3D3; color:black;width: 15%">Rate (%) </th>
                            <th class="text-center" style="background-color:#D3D3D3; color:black;width: 20%">Rule</th>
                            <th class="text-center" style="background-color:#D3D3D3; color:black;width: 20%">Total</th>
                        </tr>
                        <tr t-foreach="docs" t-as="doc1">
                            <td style="text-align:center">
                                <span t-esc="doc1['name']"/>
                            </td>
                            <td style="text-align:center">
                                <span t-esc="doc1['category_id']"/>
                            </td>
                            <td style="text-align:center">
                                <span t-esc="doc1['quantity']"/>
                            </td>
                            <td style="text-align:center">
                                <span t-esc="doc1['rate']"/>
                            </td>
                            <td style="text-align:center">
                                <span t-esc="doc1['salary_rule_id']"/>
                            </td>
                            <td style="text-align:center">
                                <span t-esc="doc1['total']"/>
                            </td>
                        </tr>
                    </table>
                </div>
            </t>
            </t>

        </template>
    </data>
</odoo>