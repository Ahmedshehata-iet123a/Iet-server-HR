<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.hr.leaves.enhance</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="70"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//app[@name='hr']" position="inside">
                <block title="Employee Leave Configurations" name="employee_leaves_setting_container">
                    <setting help="Return Vacation Date Lines for employees"
                             title="Return Vacation Date Lines for employees.">
                        <field name="hr_employee_return_date_lines"/>
                    </setting>
                </block>
            </xpath>


        </field>
    </record>


</odoo>
