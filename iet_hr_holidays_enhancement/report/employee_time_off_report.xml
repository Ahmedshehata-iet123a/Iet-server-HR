<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>

        <template id="employee_time_off_report_document">
            <t t-call="web.external_layout">
                <div class="page">
                    <div class="oe_structure"/>

                    <h2 class="mt-4 text-center">
                        <span>Employee Time Off Report</span>
                    </h2>
                    <br/>
                        <table class="table table-sm">
                            <t t-set="loop_cycle_number" t-value="0" />
                            <thead style="display: table-row-group">
                                <tr style="color: #ffffff;">
                                    <th class="text-start">Employee Number</th>
                                    <th class="text-start">Employee</th>
                                    <th class="text-start">Department</th>
                                    <th class="text-start">Time Off Type</th>
                                    <th class="text-start">Allocation Days</th>
                                    <th class="text-start">Time Off Days</th>
                                    <th class="text-start">Remaining Days</th>

                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="employees_vals" t-as="value">
                                    <t t-set="loop_cycle_number" t-value="loop_cycle_number + 1" />
                                    <tr t-att-style="'background-color: #ffffff; color: #0b5bc8;' if loop_cycle_number % 2 == 0 else 'background-color: #4d8ad4;color: #ffffff;'">
                                        <td class="text-start"><span t-esc="value['employee_number']"/></td>
                                        <td class="text-start"><t t-esc="value['employee_name']"/></td>
                                        <td class="text-start"><span t-esc="value['department_name']"/></td>
                                        <td class="text-start"><span t-esc="value['holiday_status_name']"/></td>
                                        <td class="text-start"><span t-esc="'{:.2f}'.format(value['holiday_status_days'])"/></td>
                                        <td class="text-start"><span t-esc="'{:.2f}'.format(value['taken_days'])"/></td>
                                        <td class="text-start"><span t-esc="'{:.2f}'.format(value['remaining_days'])"  t-att-style="'background-color: #ffffff; color: #0b5bc8;' if loop_cycle_number % 2 == 0 else 'background-color: #4d8ad4;color: #ffffff;'"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        <br/>
                        <br/>
                </div>
            </t>
        </template>


        <template id="employee_time_off_report_temp">
            <t t-call="web.html_container">
                <t t-call="iet_hr_holidays_enhancement.employee_time_off_report_document"/>
            </t>
        </template>

        <record id="employee_time_off_report_report" model="ir.actions.report">
            <field name="name">Employee Time Off Report</field>
            <field name="model">employee.time.off.report.wizard</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">iet_hr_holidays_enhancement.employee_time_off_report_temp</field>
            <field name="report_file">iet_hr_holidays_enhancement.employee_time_off_report_temp</field>
            <field name="binding_model_id" ref="model_employee_time_off_report_wizard"/>
            <field name="binding_type">report</field>
        </record>
    </data>
</odoo>