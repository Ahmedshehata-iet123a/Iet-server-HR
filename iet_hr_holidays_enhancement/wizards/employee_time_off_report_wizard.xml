<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <data>
        <record model='ir.ui.view' id='employee_time_off_report_wizard_view_form'>
            <field name="name">employee.time.off.report.wizard.view.form</field>
            <field name="model">employee.time.off.report.wizard</field>
            <field name="arch" type="xml">
                <form string="Employee Time Off Report">
                    <group>
                        <group>
                            <field name="employee_ids" options="{'no_create': True, 'no_create_edit':True}" widget="many2many_tags"/>
                            <field name="department_ids" options="{'no_create': True, 'no_create_edit':True}" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="holiday_status_ids" options="{'no_create': True, 'no_create_edit':True}" widget="many2many_tags"/>
                        </group>
                    </group>
                    <footer>
                        <button name="btn_report_pdf"
                                type="object"
                                default_focus="1"
                                string="Download PDF"
                                class="oe_highlight"
                                icon="fa-download"/>
                        <button string="CANCEL"
                                class="btn-danger"
                                special="cancel" />
                    </footer>
                </form>
            </field>
        </record>

        <record model='ir.actions.act_window' id='employee_time_off_report_wizard_view_action'>
            <field name="name">Employee Time Off Report</field>
            <field name="res_model">employee.time.off.report.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="employee_time_off_report_wizard_view_form"/>
            <field name="target">new</field>
        </record>


        <menuitem name="Employee Time Off Report"
                  parent="hr_holidays.menu_hr_holidays_report"
                  id="employee_time_off_report_wizard_view_action_menu"
                  sequence="3"
                  action="employee_time_off_report_wizard_view_action"/>
    </data>
</odoo>