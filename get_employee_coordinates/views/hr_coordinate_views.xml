<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_employee_coordinate_list" model="ir.ui.view">
        <field name="name">view.hr.employee.coordinate.list</field>
        <field name="model">hr.employee.coordinate</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="employee_ids" widget="many2many_tags"
                       options="{'color_field': 'color', 'no_create_edit': True}"/>
                <field name="distance"/>
                <field name="latitude"/>
                <field name="longitude"/>
            </list>
        </field>
    </record>

    <record id="view_hr_employee_coordinate_form" model="ir.ui.view">
        <field name="name">view.hr.employee.coordinate.form</field>
        <field name="model">hr.employee.coordinate</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_open_google_maps" string="Google Maps"
                            type="object" class="btn-primary"/>
                    <button name="action_get_coordinates" type="object"
                            string="Get Coordinates" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="employee_ids" widget="many2many_tags"
                                   options="{'color_field': 'color', 'no_create_edit': True}"/>
                            <field name="distance"/>
                            <field name="latitude"/>
                            <field name="longitude"/>
                        </group>
                        <group>
                            <field name="company_id" options="{'color_field': 'color', 'no_create_edit': True}"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_hr_employee_coordinate" model="ir.actions.act_window">
        <field name="name">Employee Coordinates</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hr.employee.coordinate</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new document
            </p>
        </field>
    </record>

    <menuitem id="menu_hr_employee_coordinate"
              name="Employee Coordinates"
              parent="hr.menu_hr_employee_payroll"
              action="action_hr_employee_coordinate"
              sequence="10"/>
</odoo>
