<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="hr_departure_reason_add_departure_id" model="ir.ui.view">
            <field name="name">hr.departure.reason.add.departure</field>
            <field name="model">hr.departure.reason</field>
            <field name="inherit_id" ref="hr.hr_departure_reason_view_list"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='name']" position="after">
                    <!-- Add your fields or attributes here -->
                    <field name="is_departure"/>
                </xpath>

            </field>
        </record>


        <record id="resignation_request_view_search" model="ir.ui.view">
            <field name="name">resignation_request.view.search</field>
            <field name="model">resignation.request</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="employee_id"/>
                    <field name="employee_number"/>
                    <field name="identification_id_custom"/>
                    <field name="job_id"/>
<!--                    <field name="active"/>-->
<!--                    <filter string="Archived" name="active" domain="[('active', '=', False)]"/>-->
                    <group expand="0" string="Group By">
                        <filter string="Employee" name="employee_id" context="{'group_by': 'employee_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="id_resignation_request_view_tree" model="ir.ui.view">
            <field name="name">resignation.request.view.tree</field>
            <field name="model">resignation.request</field>
            <field name="arch" type="xml">
                <list>
                    <field name="date"/>
                    <field name="name" invisible="1"/>
                    <field name="employee_id"/>
                    <field name="employee_number"/>
                    <field name="job_id"/>
                    <field name="hr_departure_id"/>
                    <field name="contract_date_end"/>
                    <field name="departure_reason"/>
                    <field name="state"/>
                </list>
            </field>
        </record>


        <record id="id_resignation_request_view_form" model="ir.ui.view">
            <field name="name">resignation.request.view.form</field>
            <field name="model">resignation.request</field>
            <field name="arch" type="xml">
                <form string="resignation">
                    <header>
                        <button name="git_confirmed" string="Confirm" type="object" state="draft"
                                class="oe_highlight" invisible="state == 'confirmed'"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group string="Employee Information">
                            <group>
                                <field name="date" readonly="state == 'confirmed'"/>
                                <field name="employee_id" readonly="state == 'confirmed'"/>
                                <field name="employee_number"/>
                                <field name="company_id"/>
                            </group>
                            <group>
                                <field name="department_id"/>
                                <field name="identification_id_custom"/>
                                <field name="custom_pin"/>
                                <field name="job_id"/>
                                <field name="parent_id"/>

                            </group>
                        </group>
                        <group string="Resignation Information">
                            <group>
                                <field name="hr_departure_id"/>
                                <field name="contract_date_end"/>
                                <field name="departure_reason"/>
                                <!--                                <field name="departure_wizard_id" states="confirmed"/>-->
                            </group>

                        </group>
                    </sheet>
                    <chatter/>

                </form>
            </field>
        </record>

        <record id="id_resignation_request_view_action" model="ir.actions.act_window">
            <field name="name">Resignation Request</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">resignation.request</field>
            <field name="view_mode">list,form</field>
        </record>


        <!-- This Menu Item must have a parent and an action -->
        <menuitem
                id="menu_end_of_service_employee"
                sequence="10"
                parent="hr.menu_hr_root"
                name="End Of Service"
        />
        <menuitem id="menu_resignation_request_categ" name="Resignation Request"
                  parent="menu_end_of_service_employee"
                  action="id_resignation_request_view_action" sequence="2"/>


        <!--    time off-->
        <menuitem
                id="menu_end_of_service_time_off"
                sequence="3"
                parent="hr_holidays.menu_hr_holidays_root"
                name="End Of Service"
        />
        <menuitem id="menu_resignation_request_time_off_categ" name="Resignation Request"
                  parent="menu_end_of_service_time_off"
                  action="id_resignation_request_view_action" sequence="2"/>
    </data>
</odoo>
