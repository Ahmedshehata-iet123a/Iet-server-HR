<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data noupdate="1">
		<record model="ir.module.category" id="module_mobikul_attendance">
			<field name="name">Mobikul Attendance App</field>
			<field name="description">Mobikul-Attendance Group</field>
			<field name="sequence">10</field>
	    </record>

		<record id="group_mobikul_attendance_user" model="res.groups">
			<field name="name">User</field>
			<field name="comment">All access except Mobikul Configuration.</field>
			<field name="category_id" ref="module_mobikul_attendance"/>
		</record>

	    <record id="group_mobikul_attendance_manager" model="res.groups">
	        <field name="name">Manager</field>
			<field name="comment">Full Access</field>
			<field name="category_id" ref="module_mobikul_attendance"/>
	        <field name="users" eval="[(4, ref('base.user_root')),(4, ref('base.user_admin'))]"/>
			 <field name="implied_ids" eval="[(4, ref('group_mobikul_attendance_user'))]"/>
	    </record>
	</data>
</odoo>