<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mobikul_attendance_res_config_settings_form" model="ir.ui.view">
        <field name="name">mobikul.attendance.res.config.settings.form.inherit</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="30"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <div class="app_settings_block" data-string="Mobikul Attendance" data-key="mobikul_odoo_attendance" string="Mobikul Attendance">
                    <h2> Mobikul Attendance Configure</h2>
                    <div class="row mt16 o_settings_container" id="Mobikul_Attendance_selection_settings" groups="mobikul_odoo_attendance.group_mobikul_attendance_manager">
                        <div class="col-xs-12 col-md-6 o_setting_box" id="at_website">
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Mobikul Attendance Configuration</span>
                                <div class="text-muted">
                                    Settings on this menu page will apply to mobikul attendance
                                </div>

                                <div>
                                    <button type="object" name="open_mobikul_attendance_conf" string="Configuration" class="oe_inline oe_link" icon="fa-cogs"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <h2>Extra Features</h2>
                    <div class="row mt16 o_settings_container" id="mobikil_attendance_extra_feacture">
                        <div class="col-12 col-lg-6 o_setting_box" id="m_attendance_reset_password" groups="mobikul_odoo_attendance.group_mobikul_attendance_manager">
                            <div class="o_setting_left_pane">
                                <field name="m_attendance_reset_password"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label string="Allow Reset Password" for="m_attendance_reset_password"/>
                                <div class="text-muted">
                                Allow Reset Password on APP
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
    <record id="action_mobikul_attendance_configuration" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="mobikul_odoo_attendance.mobikul_attendance_res_config_settings_form"/>
        <field name="target">inline</field>
        <field name="context">{'module' : 'mobikul_odoo_attendance'}</field>
    </record>
</odoo>