<odoo>
    <record id="fcm_attendance_devices_view_tree" model="ir.ui.view">
        <field name="name">fcm_attendance_devices.tree</field>
        <field name="model">fcm.attendance.devices</field>
        <field name="arch" type="xml">
            <list string="Registered Devices">
                <field name="customer_id"/>
                <field name="device_id"/>
                <field name="create_date"/>
                <field name="write_date"/>
            </list>
        </field>
    </record>
    <record id="fcm_attendance_devices_action" model="ir.actions.act_window">
        <field name="name">FCM Registered Devices</field>
        <field name="res_model">fcm.attendance.devices</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="fcm_attendance_devices_view_tree"/>
    </record>

    <!-- Notification Messages  -->
    <record id="mobikul_attendance_massages_view_tree" model="ir.ui.view">
        <field name="name">mobikul_attendance_massages.tree</field>
        <field name="model">mobikul.attendance.messages</field>
        <field name="arch" type="xml">
            <list string="Notification Messages" create="false">
                <field name="name"/>
                <field name="is_read"/>
                <field name="customer_id"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>
    <record id="mobikul_attendance_massages_view_form" model="ir.ui.view">
        <field name="name">mobikul_attendance_massages.form</field>
        <field name="model">mobikul.attendance.messages</field>
        <field name="arch" type="xml">
            <form string="Notification Messages">
               <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button" options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" default_focus="1" placeholder="Record name"/>
                        </h1>
                    </div>
                    <br/>
                    <br/>

                    <notebook>
                        <page string="Information">
                        <separator string="Content to be displayed in Notification Message" colspan="4"/>
                            <field name="title" colspan="4" placeholder="Title"/>
                            <separator/>
                            <field name="subtitle" colspan="4" placeholder="Subtitle"/>
                            <field name="body" colspan="4" placeholder="Body"/>
                            <group>
                                <group>
                                    <field name="icon" widget="image" class="oe_avatar"/>
                                </group>
                                <group>
                                    <field name="datatype"/>
                                    <field name="is_read" />
                                    <field name="customer_id"/>
                                    <field name="period" />
                                </group>

                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div>
                    <div class="oe_edit_only"
                         invisible="not banner">
                        <h1>Change Banner Image</h1>
                    </div>
                    <div class="oe_edit_only" invisible="banner">
                        <h1>Upload Banner Image</h1>
                    </div>
                    <field name="banner" widget="image" colspan="4"/>
                </div>
            </form>
        </field>
    </record>
    <record id="mobikul_attendance_massages_filter_view" model="ir.ui.view">
        <field name="name">Mobikul Attendance Messages Search</field>
        <field name="model">mobikul.attendance.messages</field>
        <field name="arch" type="xml">
            <search string="Mobikul Attendance Notification Messages">
                <field name="customer_id"/>
                <group expand="0" string="Group By">
                        <filter string="Customer" name="customer" context="{'group_by':'customer_id'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="mobikul_attendance_massages_templates_action" model="ir.actions.act_window">
        <field name="name">Mobikul Attendance Messages</field>
        <field name="res_model">mobikul.attendance.messages</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="mobikul_attendance_massages_view_tree"/>
        <field name="context">{'search_default_group_customer_id': 1}</field>

        <field name="search_view_id" ref="mobikul_attendance_massages_filter_view"/>
        <field name="help" type="html">
          <p class="oe_view_nocontent_create">
            Notification Messages for your Mobikul Attendance App.
          </p>
        </field>
    </record>
    <!-- Notification Messages Ends here  -->
</odoo>