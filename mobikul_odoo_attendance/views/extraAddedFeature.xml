<odoo>
    <!-- Template Action and view  -->
    <record id="mobikul_atd_notification_template_view_form" model="ir.ui.view">
        <field name="name">mobikul.attendance.notification.template.form</field>
        <field name="model">mobikul.attendance.notification.template</field>
        <field name="arch" type="xml">
            <form string="Push Notification Template">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button" options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <div class="oe_edit_only">
                            <label for="name" string="Name"/>
                        </div>
                        <h1>
                            <field name="name" default_focus="1" placeholder="Record name"/>
                        </h1>
                    </div>
                    <notebook>
                        <page string="Information">
                        <separator string="Notification will be triggered automatically when" colspan="4"/>
                            <group>
                                <field name="condition" required="1"/>
                            </group>
                        <separator string="Content to be displayed in Push Notification" colspan="4"/>
                            <field name="notification_title" colspan="4" placeholder="Title"/>
                            <field name="notification_body" colspan="4" placeholder="Body"/>
                        </page>
                        <page string="Advanced">
                            <group>
                                <group>
                                    <field name="notification_color"/>
                                    <field name="notification_tag"/>
                                </group>
                                <group>
                                    <field name="total_views" invisible="1"/>
                                </group>
                                <group>
                                    <field name="device_id" widget="selection"/>

                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="mobikul_atd_notification_template_view_tree" model="ir.ui.view">
        <field name="name">mobikul.attendance.notification.template.tree</field>
        <field name="model">mobikul.attendance.notification.template</field>
        <field name="arch" type="xml">
            <list string="Push Notification Templates">
                <field name="name"/>
                <field name="notification_title"/>
            </list>
        </field>
    </record>
    <record id="mobikul_atd_notification_templates_action" model="ir.actions.act_window">
        <field name="name">Push Notifications Templates</field>
        <field name="res_model">mobikul.attendance.notification.template</field>
        <field name="view_mode">list,form</field>
        <!-- <field name="view_type">form</field> -->
        <field name="help" type="html">
          <p class="oe_view_nocontent_create">
            Click to add a new Push Notification Templates for your Mobikul App.
          </p>
        </field>
    </record>
    <!-- Template Action and view ends here  -->

    <!-- Attendance One time Push Notification Start -->
    <record id="mobikul_atd_notification_view_form" model="ir.ui.view">
        <field name="name">mobikul.attendance.notification.form</field>
        <field name="model">mobikul.attendance.notification</field>
        <field name="arch" type="xml">
            <form string="Attendance Push Notification">
                <header>
                    <button name="action_confirm"
                            invisible="state != 'draft'"
                            type="object" string="Confirm" class="oe_highlight"/>
                    <button name="action_draft" invisible="state not in ['cancel', 'hold']" type="object" string="Set to Draft"/>
                    <button name="action_hold" invisible="state != 'confirm'" type="object" string="Set to Hold"/>
                    <button name="action_confirm" invisible="state != 'hold'" type="object" string="Release Hold" class="oe_highlight"/>
                    <button name="action_cancel" invisible="state not in ['draft', 'hold']" type="object" string="Cancel"/>
                    <button name="push_now" invisible="state != 'confirm'" type="object" string="Push now" class="oe_highlight"/>
                    <button name="duplicate_me" invisible="state != 'done'" type="object" string="Duplicate" />
                    <button name="push_now" invisible="state != 'error'" type="object" string="Retry" class="oe_highlight"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirm,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button" options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <div class="oe_edit_only">
                            <label for="name" string="Name"/>
                        </div>
                        <h1>
                            <field name="name" default_focus="1" placeholder="Record name"/>
                        </h1>
                    </div>
                    <br/>
                    <br/>
                    <separator string="Result" colspan="4" invisible="state not in ['done','error']"/>
                            <field name="summary" colspan="4" invisible="state not in ['done','error']"/>
                    <notebook>
                        <page string="Information">
                        <separator string="Content to be displayed in Push Notification" colspan="4"/>
                            <field name="notification_title" colspan="4" placeholder="Title"/>
                            <field name="notification_body" colspan="4" placeholder="Body"/>
                        </page>
                        <page string="Advanced">
                            <separator string="Notification Type" colspan="4"/>
                            <group>
                                <group>
                                    <field name="notification_type"/>
                                </group>
                                <group>
                                    <field name="topic_id"
                                           invisible="notification_type in ['token-auto','token-manual']"
                                           required="notification_type == 'topic'" widget="selection"/>
                                    <field name="device_ids"
                                           invisible="notification_type in ['topic','token-auto']"
                                           required="notification_type == 'token-manual'" widget="many2many_tags" quick_create="false"/>
                                </group>
                            </group>
                            <separator string="Others" colspan="4"/>
                            <group>
                                <group>
                                    <field name="activation_date" invisible="1"/>
                                    <field name="notification_color"/>
                                    <field name="notification_tag"/>
                                </group>
                                <group>
                                    <field name="total_views" invisible="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="mobikul_atd_notification_filter_view" model="ir.ui.view">
        <field name="name">mobikul_attendance_notification.search.mobikul</field>
        <field name="model">mobikul.attendance.notification</field>
        <field name="arch" type="xml">
            <search string="Mobikul Attendance Push Notification">
                <field name="name" string="Attendance Notification" filter_domain="[('name','ilike',self)]"/>
                <separator/>
                <filter string="Archived" name="inactive" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>
    <record id="mobikul_atd_notification_view_tree" model="ir.ui.view">
        <field name="name">mobikul.attendance.notification.tree</field>
        <field name="model">mobikul.attendance.notification</field>
        <field name="arch" type="xml">
            <list string="Attendance Push Notifications" >
                <field name="name"/>
                <field name="activation_date" invisible="1"/>
                <field name="state"/>
            </list>
        </field>
    </record>
    <record id="mobikul_atd_notification_action" model="ir.actions.act_window">
        <field name="name">Mobikul Attendance Push Notifications</field>
        <field name="res_model">mobikul.attendance.notification</field>
        <field name="view_mode">list,form</field>
        <!-- <field name="view_type">form</field> -->
        <field name="view_id" ref="mobikul_atd_notification_view_tree"/>
        <field name="search_view_id" ref="mobikul_atd_notification_filter_view"/>
        <field name="help" type="html">
          <p class="oe_view_nocontent_create">
            Click to add a new Push Notification for your Mobikul App.
          </p>
        </field>
    </record>
    <!-- Attendance One time Push Notification Ends  -->

    <!-- FCM TOPIC VIEW  -->
    <record id="fcm_attendance_topics_view_tree" model="ir.ui.view">
        <field name="name">fcm_attendance_topics.tree</field>
        <field name="model">fcm.attendance.topics</field>
        <field name="arch" type="xml">
            <list string="All FCM Topics" editable="top">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="fcm_attendance_topics_action" model="ir.actions.act_window">
        <field name="name">FCM Registered Topics</field>
        <field name="res_model">fcm.attendance.topics</field>
        <field name="view_mode">list</field>
        <!-- <field name="view_type">form</field> -->
        <field name="view_id" ref="fcm_attendance_topics_view_tree"/>
    </record>
    <!-- ENDS HERE  -->

</odoo>